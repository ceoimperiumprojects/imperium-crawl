  {
    "id": "workflow/realauction-miamidade",
    "name": "RealAuction Miami-Dade",
    "description": "Scrape RealAuction Miami-Dade foreclosures",
    "steps": [
      {
        "name": "scrape_auction",
        "tool": "scrape",
        "input": {
          "url": "https://miamidade.realforeclose.com/index.cfm?zaction=AUCTION&Zmethod=PREVIEW&AUCTIONDATE=03/25/2026",
          "format": "markdown"
        },
        "validate": {
          "has_content": true,
          "min_length": 100
        }
      }
    ],
    "requires_browser": true
  },
