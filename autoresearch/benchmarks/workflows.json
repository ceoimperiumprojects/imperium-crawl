  {
    "id": "workflow/crawl-and-extract",
    "name": "Crawl and Extract",
    "description": "Crawl books.toscrape then extract titles from the page",
    "steps": [
      {
        "name": "crawl_site",
        "tool": "crawl",
        "input": {
          "url": "https://books.toscrape.com",
          "max_depth": 1,
          "max_pages": 3
        },
        "validate": {
          "has_content": true,
          "min_length": 100
        }
      },
      {
        "name": "extract_books",
        "tool": "extract",
        "input": {
          "url": "https://books.toscrape.com",
          "items_selector": "article.product_pod",
          "selectors": {
            "title": "h3 a @title",
            "price": ".price_color"
          }
        },
        "validate": {
          "has_content": true
        }
      }
    ]
  },
