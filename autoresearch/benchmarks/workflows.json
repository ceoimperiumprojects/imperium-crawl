[
  {
    "id": "workflow/search-readability",
    "name": "Search then Readability",
    "description": "Search for AI startups, then extract article content from top results",
    "steps": [
      {
        "name": "search",
        "tool": "search",
        "input": {
          "query": "AI startups 2024"
        },
        "validate": {
          "has_content": true,
          "min_length": 100
        },
        "extract": "first_url"
      }
    ],
    "requires_env": [
      "BRAVE_API_KEY"
    ]
  },
  {
    "id": "workflow/ecommerce-extract",
    "name": "E-Commerce Product Extract",
    "description": "Extract product data from multiple pages",
    "steps": [
      {
        "name": "extract_product",
        "tool": "scrape",
        "input": {
          "url": "https://httpbin.org/html",
          "format": "markdown"
        },
        "validate": {
          "has_content": true,
          "min_length": 50
        }
      }
    ]
  },
  {
    "id": "workflow/hn-recipe-follow",
    "name": "Hacker News RSS Follow",
    "description": "Parse HN via RSS, then extract article",
    "steps": [
      {
        "name": "hn_rss",
        "tool": "rss",
        "input": {
          "url": "https://hnrss.org/frontpage"
        },
        "validate": {
          "has_content": true
        }
      }
    ]
  },
  {
    "id": "workflow/json-api-fetch",
