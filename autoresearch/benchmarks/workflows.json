        "tool": "scrape",
        "input": {
          "url": "https://apps.miamidadepa.gov/PApublicServiceProxy/PaServicesProxy.ashx?Operation=GetPropertySearchByFolio&clientAppName=PropertySearch&folioNumber=3021090120010",
          "format": "markdown"
        },
        "validate": {
          "has_content": true,
          "min_length": 50
        }
      }
    ]
  },
