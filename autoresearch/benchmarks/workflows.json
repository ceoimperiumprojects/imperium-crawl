      {
        "name": "scrape_api",
        "tool": "scrape",
        "input": {
          "url": "https://jsonplaceholder.typicode.com/posts/1",
          "format": "markdown"
        },
        "validate": {
          "has_content": true,
          "min_length": 50
        }
      }
    ]
  },
