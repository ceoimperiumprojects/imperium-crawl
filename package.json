{
  "name": "imperium-crawl",
  "version": "2.5.0",
  "description": "33-tool open-source CLI for web scraping, PDF extraction, content monitoring, RSS aggregation, and custom skills. Zero API keys for core tools.",
  "type": "module",
  "bin": {
    "imperium-crawl": "dist/index.js",
    "imperiumcrawl": "dist/index.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./tools/*": "./dist/tools/*.js",
    "./stealth/*": "./dist/stealth/*.js",
    "./sessions": "./dist/sessions/index.js",
    "./sessions/*": "./dist/sessions/*.js",
    "./utils/*": "./dist/utils/*.js"
  },
  "files": [
    "dist",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/index.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "autoresearch": "tsx autoresearch/eval.ts",
    "autoresearch:baseline": "tsx autoresearch/eval.ts --baseline --verbose"
  },
  "keywords": [
    "scraping",
    "crawling",
    "web-search",
    "brave-search",
    "firecrawl",
    "cli",
    "pdf-extract",
    "web-monitoring",
    "url-watch",
    "content-diff",
    "intelligence-digest"
  ],
  "author": "ImperiumTech",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@distube/ytdl-core": "^4.16.12",
    "@inquirer/prompts": "^8.3.0",
    "@mozilla/readability": "^0.5.0",
    "chalk": "^5.6.2",
    "cheerio": "^1.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "header-generator": "^2.1.66",
    "impit": "^0.9.2",
    "jsdom": "^26.0.0",
    "linkedom": "^0.18.12",
    "normalize-url": "^8.1.1",
    "ora": "^8.2.0",
    "p-queue": "^8.1.1",
    "pdfjs-dist": "^4.0.379",
    "playwright": "1.52",
    "robots-parser": "^3.0.1",
    "rss-parser": "^3.13.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^3.24.2"
  },
  "optionalDependencies": {
    "fingerprint-injector": "^2.1.62",
    "rebrowser-playwright": "^1.51.1"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.5",
    "@types/turndown": "^5.0.5",
    "shx": "^0.3.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
