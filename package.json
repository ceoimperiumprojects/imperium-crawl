{
  "name": "imperium-crawl",
  "version": "1.5.2",
  "description": "Open-source MCP server with Firecrawl-like scraping, crawling, search, and custom skills",
  "type": "module",
  "bin": {
    "imperium-crawl": "dist/index.js",
    "imperiumcrawl": "dist/index.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./tools/*": "./dist/tools/*.js",
    "./stealth/*": "./dist/stealth/*.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/index.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "scraping",
    "crawling",
    "web-search",
    "brave-search",
    "firecrawl",
    "model-context-protocol"
  ],
  "author": "ImperiumTech",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@mozilla/readability": "^0.5.0",
    "chalk": "^5.6.2",
    "cheerio": "^1.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "header-generator": "^2.1.66",
    "impit": "^0.9.2",
    "jsdom": "^26.0.0",
    "linkedom": "^0.18.12",
    "normalize-url": "^8.1.1",
    "ora": "^8.2.0",
    "p-queue": "^8.1.1",
    "playwright": "1.52",
    "robots-parser": "^3.0.1",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^3.24.2"
  },
  "optionalDependencies": {
    "fingerprint-injector": "^2.1.62",
    "rebrowser-playwright": "^1.51.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.5",
    "@types/turndown": "^5.0.5",
    "shx": "^0.3.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
